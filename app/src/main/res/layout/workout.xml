<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="#2E2E2E"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/workoutSport"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sport"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/workoutDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Date"
        android:textColor="@android:color/white" />

    <TextView
        android:id="@+id/workoutDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Duration"
        android:textColor="@android:color/white" />

    <TextView
        android:id="@+id/workoutDistance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Distance"
        android:textColor="@android:color/white" />

    <TextView
        android:id="@+id/workoutPace"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Pace"
        android:textColor="@android:color/white" />

    <TextView
        android:id="@+id/workoutHeartRate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Heart rate"
        android:textColor="@android:color/white" />

    <TextView
        android:id="@+id/workoutExercises"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Exercises"
        android:textColor="@android:color/white"
        android:visibility="gone" />

    <TextView
        android:id="@+id/workoutNotes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Notes"
        android:textColor="@android:color/white" />
</LinearLayout>