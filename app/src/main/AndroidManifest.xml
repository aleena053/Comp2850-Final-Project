        <activity android:name=".WorkoutHistory" />
        <activity android:name=".WorkoutDetail" />
        <activity android:name=".TrainerDashboard" />
        <activity android:name=".ClientWorkoutHistory" />
        <activity android:name=".CreateTrainingPlan" />
